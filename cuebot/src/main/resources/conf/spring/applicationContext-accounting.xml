<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
         http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans-2.5.xsd">

  <!-- ##################################################################################### -->
  <!-- Redis-backed accounting publishing                                                    -->
  <!-- See design/SCHED_REDIS_DECISIONS.md for the protocol.                                 -->
  <!--                                                                                       -->
  <!-- A single bean whose runtime behavior is gated by accounting.redis.enabled. When       -->
  <!-- false, initialize() short-circuits before connecting and publishRelease() is a no-op  -->
  <!-- — which is also how tests avoid dialing Redis.                                        -->
  <!-- ##################################################################################### -->

  <bean id="accountingRedisPublisher"
        class="com.imageworks.spcue.service.LettuceAccountingRedisPublisher"/>

</beans>
