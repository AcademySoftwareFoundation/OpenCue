<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
         http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans-2.5.xsd">

  <!-- ##################################################################################### -->
  <!-- Scheduler accounting NOTIFY publishing                                                -->
  <!-- See docs/_docs/developer-guide/scheduler-accounting.md for the wire contract.         -->
  <!--                                                                                       -->
  <!-- Emits release + enforced cap-change deltas to the standalone Rust scheduler via        -->
  <!-- Postgres pg_notify, INSIDE the same transaction as the DB write each describes (so a   -->
  <!-- delta is delivered iff that transaction commits). Runtime behavior is gated by         -->
  <!-- accounting.notify.enabled; when false every method is a no-op. Shares cueDataSource so  -->
  <!-- its JdbcTemplate participates in the caller's thread-bound transaction.                -->
  <!-- ##################################################################################### -->

  <bean id="accountingNotifier"
        class="com.imageworks.spcue.service.AccountingNotifier">
    <property name="dataSource" ref="cueDataSource"/>
  </bean>

</beans>
