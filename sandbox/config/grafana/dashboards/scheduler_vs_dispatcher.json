  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Goal: Decrease time-to-book for ready frames (Cuebot \u27f5 left | Scheduler \u27f6 right)",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "panels": []
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Cuebot \u2014 Time to book (s)",
      "description": "Time a WAITING frame spent before Cuebot booked it. New metric cue_frame_time_to_book_seconds, mirrors the scheduler histogram.",
      "datasource": "prometheus",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 8,
            "showPoints": "never",
            "stacking": {
              "mode": "none",
              "group": "A"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "last",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": "prometheus",
          "expr": "histogram_quantile(0.50, sum(rate(cue_frame_time_to_book_seconds_bucket{show=~\"$cuebot_show\"}[$__rate_interval])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": "prometheus",
          "expr": "histogram_quantile(0.95, sum(rate(cue_frame_time_to_book_seconds_bucket{show=~\"$cuebot_show\"}[$__rate_interval])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "datasource": "prometheus",
          "expr": "histogram_quantile(0.99, sum(rate(cue_frame_time_to_book_seconds_bucket{show=~\"$cuebot_show\"}[$__rate_interval])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
