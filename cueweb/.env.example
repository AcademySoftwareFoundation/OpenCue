NEXT_PUBLIC_OPENCUE_ENDPOINT=http://your-rest-gateway-url.com

# Optional allow-list for the frame preview route (/api/frame/preview), as a
# colon-separated list of absolute path prefixes. When set, the server only
# serves preview images located under one of these roots. When unset, preview
# reads are not restricted to a root (set this to harden the deployment).
# CUEWEB_PREVIEW_ROOTS=/mnt/render:/shows

# Short Git SHA shown in the "About CueWeb" dialog (Help -> About CueWeb).
# Build-time only; CI injects it, e.g.
#   docker build --build-arg NEXT_PUBLIC_GIT_SHA=$(git rev-parse --short HEAD) ...
# Defaults to empty (the dialog shows "unknown").
# NEXT_PUBLIC_GIT_SHA=

# Cuebot Facility switching (CueGUI "Cuebot Facility" menu parity).
# NEXT_PUBLIC_CUEBOT_FACILITIES lists the facilities shown in the header menu
# (comma-separated). Defaults to "local,dev,cloud,external" when unset.
# NEXT_PUBLIC_CUEBOT_FACILITIES=local,dev,cloud,external
#
# Each facility may point at its own REST gateway + JWT secret via paired,
# server-only vars named CUEBOT_<NAME>_REST_GATEWAY_URL and
# CUEBOT_<NAME>_JWT_SECRET (NAME uppercased). A facility with no override falls
# back to NEXT_PUBLIC_OPENCUE_ENDPOINT / NEXT_JWT_SECRET, so the default
# deployment works with only the "local" facility wired up.
# CUEBOT_DEV_REST_GATEWAY_URL=http://dev-rest-gateway:8448
# CUEBOT_DEV_JWT_SECRET=dev-gateway-jwt-secret
# CUEBOT_CLOUD_REST_GATEWAY_URL=https://cloud-rest-gateway.example.com
# CUEBOT_CLOUD_JWT_SECRET=cloud-gateway-jwt-secret

# Optional allow-list for the Stuck Frames "Last Line" reader
# (/api/stuck-frames/lastline), as a colon-separated list of absolute path
# prefixes. When set, only .rqlog files under one of these roots are read.
# When unset, reads are not restricted to a root (job log paths are
# site-specific). Set this to harden the deployment.
# CUEWEB_LOG_ROOTS=/mnt/logs:/shows

# Sentry values
SENTRY_ENVIRONMENT='development'
SENTRY_DSN = sentrydsn
SENTRY_URL = sentryurl
SENTRY_ORG = sentryorg
SENTRY_PROJECT = sentryproject

# Authentication Configuration:
NEXT_PUBLIC_AUTH_PROVIDER=github,okta,google,ldap
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=canbeanything

# Authorization (optional, group-based access control enforced by middleware.ts).
# Leave the group lists empty to keep the default: every signed-in user is
# allowed and is treated as an admin. Group gating requires an auth provider
# whose token carries group memberships. Values are comma-separated group names.
#   CUEWEB_AUTHZ_ENABLED   master switch; opt-in. Set to true to enable the
#                          gate. Default: disabled (pure pass-through).
#   CUEWEB_ALLOWED_GROUPS  groups allowed to use CueWeb at all
#   CUEWEB_ADMIN_GROUPS    groups allowed to use the CueCommander admin pages
#   CUEWEB_GROUPS_CLAIM    JWT/OIDC claim that holds the user's groups (default: groups)
CUEWEB_AUTHZ_ENABLED=false
CUEWEB_ALLOWED_GROUPS=
CUEWEB_ADMIN_GROUPS=
CUEWEB_GROUPS_CLAIM=groups

# LDAP
LDAP_URI=ldaps://company.ldap:636
LDAP_LOGIN_DN="uid={login},cn=users,cn=accounts,dc=tobeoverriden"
LDAP_CERTIFICATE=/etc/ssl/custom.crt

# values from Okta OAuth 2.0
NEXT_AUTH_OKTA_CLIENT_ID=oktaid
NEXT_AUTH_OKTA_ISSUER=https://company.okta.com
NEXT_AUTH_OKTA_CLIENT_SECRET=oktasecret

# values from Google Cloud Platform OAuth 2.0
GOOGLE_CLIENT_ID=googleclientid
GOOGLE_CLIENT_SECRET=googleclientsecret

# values from Github OAuth 2.0
GITHUB_ID=githubid
GITHUB_SECRET=githubsecret